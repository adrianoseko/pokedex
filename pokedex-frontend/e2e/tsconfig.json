/*
  TypeScript configuration for end-to-end (e2e) tests.
  This file extends the project's base tsconfig and provides compiler
  options specific to the e2e test environment.
  For more details: https://angular.io/config/tsconfig
*/
{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "outDir": "../out-tsc/e2e",
    "module": "commonjs",
    "target": "es2018",
    "types": [
      "jasmine",
      "node"
    ]
  }
}
