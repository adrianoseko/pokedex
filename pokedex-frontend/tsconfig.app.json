/* To learn more about this file see: https://angular.io/config/tsconfig. */
{
  "extends": "./tsconfig.json",

  /* Compiler options for the application build (overrides from the base) */
  "compilerOptions": {
    "outDir": "./out-tsc/app",
    "types": []
  },

  /* Application entry points */
  "files": [
    "src/main.ts",
    "src/polyfills.ts"
  ],

  /* Include type declaration files */
  "include": [
    "src/**/*.d.ts"
  ]
}
